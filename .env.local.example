NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (SAR / Mada via Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
STRIPE_COMPANY_ANNUAL_PRICE_ID=price_...

# OpenAI (VORA AI Ecosystem)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Super Admin access (demo: vora-owner-2026)
NEXT_PUBLIC_ADMIN_ACCESS_TOKEN=vora-owner-2026

# JWT Session Security (HTTP-only cookies)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
PASSWORD_PEPPER=vora-pepper-2026

# Email delivery (configure Resend/SendGrid in production)
# RESEND_API_KEY=re_...
VORA_OWNER_EMAIL=owner@vora.sa

# Production & SEO
NEXT_PUBLIC_SITE_URL=https://vora.sa

# Redis cache (Upstash or compatible — Cloudflare/CDN layer)
# REDIS_URL=https://your-redis.upstash.io
# REDIS_TOKEN=your-redis-token

# Monitoring (Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Vercel Cron backup (daily 03:00 UTC)
CRON_SECRET=change-me-in-vercel-dashboard
# BACKUP_STORAGE_URL=s3://saudi-cloud-vora-backups
