# =============================================================================
# VORA — Environment Variables
# Copy to `.env.local` for local dev; mirror Production vars in Vercel dashboard.
# See docs/PRODUCTION_LAUNCH_CHECKLIST.md for the full pre-launch matrix.
# =============================================================================

# --- Supabase (required) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Platform owner / RBAC (required) ----------------------------------------
# Email address of the platform owner — not a password.
VORA_PLATFORM_OWNER_EMAIL=owner@your-domain.com

# --- Dev / staging only — NEVER set in production ----------------------------
# Bootstrap passwords for local demo accounts. Demo removal is deferred until
# legal approval; these must not appear in Vercel Production env.
# VORA_PLATFORM_OWNER_BOOTSTRAP_PASSWORD=
# VORA_MANUAL_TEST_USER_BOOTSTRAP_PASSWORD=
# VORA_MANUAL_TEST_USER_EMAIL=
# VORA_DEMO_DEFAULT_PASSWORD=

# --- Auth secrets (required) -------------------------------------------------
# Must be long random values in production — app throws on dev defaults in prod.
JWT_SECRET=change-this-to-a-long-random-secret-in-production
PASSWORD_PEPPER=change-this-to-a-long-random-pepper-in-production

# --- Site URL (required for production) --------------------------------------
# Used for password reset redirects and absolute links.
NEXT_PUBLIC_SITE_URL=https://vora.sa

# --- Billing / payments ------------------------------------------------------
# Soft launch: keep simulation until legal approval for Stripe live.
# BILLING_PAYMENT_MODE=simulation   ← valid production interim state
# BILLING_PAYMENT_MODE=stripe       ← deferred until legal approval
# BILLING_PAYMENT_MODE=moyasar
# BILLING_PAYMENT_MODE=tap

# Stripe live keys — DEFERRED until legal approval. Do not enable in production
# until sign-off. Simulation billing works without these.
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
# STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
# STRIPE_COMPANY_ANNUAL_PRICE_ID=price_...

# --- OTP / SMS / WhatsApp (required for production soft launch) --------------
# Console fallback when keys are unset in non-production only.
# OTP_PROVIDER=auto
# OTP_PROVIDER=twilio
# OTP_PROVIDER=resend
# OTP_PROVIDER=console
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_SMS_FROM=+966XXXXXXXXX
# TWILIO_WHATSAPP_FROM=whatsapp:+966XXXXXXXXX

# --- Email (required for production soft launch) -----------------------------
# Console fallback when RESEND_API_KEY is unset in non-production only.
# EMAIL_TRANSPORT_MODE=auto
# EMAIL_TRANSPORT_MODE=resend
# EMAIL_TRANSPORT_MODE=console
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=notifications@vora.sa
# RESEND_REPLY_TO=support@vora.sa

# Legacy owner email alias (optional if VORA_PLATFORM_OWNER_EMAIL is set)
VORA_OWNER_EMAIL=owner@vora.sa

# --- Cron (required for production) ------------------------------------------
# Vercel cron sends: Authorization: Bearer <CRON_SECRET>
# Schedules in vercel.json: backup 03:00 UTC, search-reindex every 6h,
# subscription-reconcile 04:00 UTC
CRON_SECRET=change-me-in-vercel-dashboard

# Optional backup upload target — HTTPS POST endpoint for JSON manifest snapshots.
# When unset, backups write local manifests under .data/vora/backups/
# BACKUP_STORAGE_URL=https://your-backup-endpoint.example/upload

# Optional local JSON data directory (defaults to /tmp/vora on Vercel)
# VORA_DATA_DIR=

# --- Redis cache (optional — recommended for production) ---------------------
# Rate limits + search cache use in-memory fallback when unset.
# 1. Create a database at https://console.upstash.com/redis
# 2. Copy REST URL → REDIS_URL and REST token → REDIS_TOKEN
# REDIS_URL=https://your-redis.upstash.io
# REDIS_TOKEN=your-redis-token

# --- Monitoring / Sentry (optional — recommended for production) -------------
# App builds and runs without these; errors log to console only.
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=vora
# SENTRY_AUTH_TOKEN=sntrys_...  # optional — enables source map upload on build

# --- OpenAI (optional — VORA AI Ecosystem) -----------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Diagnostics endpoints
# =============================================================================
# Public health probe:     GET /api/health
# Owner launch readiness:  GET /api/admin/launch/readiness
# Owner billing:           GET /api/admin/billing/diagnostics
# Owner notifications:     GET /api/admin/notifications/diagnostics
# Owner cron:              GET /api/admin/cron/diagnostics
# Owner cache:             GET /api/admin/cache/diagnostics
# Owner monitoring:        GET /api/admin/monitoring/diagnostics
