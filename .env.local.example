NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Platform owner (RBAC — not a password)
VORA_PLATFORM_OWNER_EMAIL=owner@your-domain.com

# Dev-only bootstrap passwords (optional — never commit real values)
# VORA_PLATFORM_OWNER_BOOTSTRAP_PASSWORD=
# VORA_MANUAL_TEST_USER_BOOTSTRAP_PASSWORD=
# VORA_MANUAL_TEST_USER_EMAIL=
# VORA_DEMO_DEFAULT_PASSWORD=

# Billing / payments (defaults to local simulation when no gateway keys are set)
# BILLING_PAYMENT_MODE=simulation
# BILLING_PAYMENT_MODE=stripe
# BILLING_PAYMENT_MODE=moyasar
# BILLING_PAYMENT_MODE=tap

# Stripe (optional — enable when you have a Stripe account)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
# STRIPE_PREMIUM_YEARLY_PRICE_ID=price_...
# STRIPE_COMPANY_ANNUAL_PRICE_ID=price_...

# OpenAI (VORA AI Ecosystem)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# JWT Session Security (legacy OTP path + required in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
PASSWORD_PEPPER=change-this-to-a-long-random-pepper-in-production

# Email delivery (Resend — console fallback when RESEND_API_KEY is unset in non-production)
# EMAIL_TRANSPORT_MODE=auto
# EMAIL_TRANSPORT_MODE=resend
# EMAIL_TRANSPORT_MODE=console
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=notifications@vora.sa
# RESEND_REPLY_TO=support@vora.sa

# OTP / SMS / WhatsApp (Twilio — console fallback when keys are unset in non-production)
# OTP_PROVIDER=auto
# OTP_PROVIDER=twilio
# OTP_PROVIDER=console
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_SMS_FROM=+966XXXXXXXXX
# TWILIO_WHATSAPP_FROM=whatsapp:+966XXXXXXXXX
VORA_OWNER_EMAIL=owner@vora.sa

# Production & SEO (required for password reset redirects)
NEXT_PUBLIC_SITE_URL=https://vora.sa

# Redis cache (Upstash or compatible — optional)
# REDIS_URL=https://your-redis.upstash.io
# REDIS_TOKEN=your-redis-token

# Monitoring (Sentry — optional; app builds and runs without these)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=vora
# SENTRY_AUTH_TOKEN=sntrys_...  # optional — enables source map upload on build

# Readiness probe (public, no auth): GET /api/health
# Returns { status, timestamp, checks: { supabase, stripe, otp, email, cron } }

# Vercel Cron (Authorization: Bearer CRON_SECRET — set in Vercel dashboard, never commit)
# Schedules (vercel.json): backup 03:00 UTC, search-reindex every 6h, subscription-reconcile 04:00 UTC
CRON_SECRET=change-me-in-vercel-dashboard

# Optional backup upload target — HTTPS POST endpoint for JSON manifest snapshots.
# s3:// URIs are recorded but require an external uploader or presigned HTTPS URL.
# When unset, backups write local manifests under .data/vora/backups/ (graceful partial status).
# BACKUP_STORAGE_URL=https://your-backup-endpoint.example/upload

# Optional local JSON data directory (defaults to /tmp/vora on Vercel)
# VORA_DATA_DIR=
